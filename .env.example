# DevOps Pipeline Gym environment variables
# Copy to .env and fill in values. .env is gitignored; never commit secrets.
#
# The env deliberately ships ZERO external API deps in the runtime path —
# rewards are pure deterministic Python. Env vars below reflect only what
# is consumed by the shipped code (inference + optional task overrides).

# --- HuggingFace (REQUIRED — inference.py raises ValueError if missing) -------
HF_TOKEN=hf_your_token_here

# --- Optional overrides for inference.py + eval_baseline.py -------------------
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# --- Optional env-control flags -----------------------------------------------
# DEVOPS_TASK=clean_deploy           # force a specific task on env reset
# DEVOPS_SEED=6006                   # override seed for random_incident
# ENABLE_WEB_INTERFACE=true          # enable Gradio UI at /web (HF Space)

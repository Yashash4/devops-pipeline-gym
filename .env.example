# Round 2 — DevOps Pipeline Gym environment variables
# Copy to .env and fill in values. .env is gitignored; never commit secrets.

# --- HuggingFace (required by inference.py + openenv push) --------------------
HF_TOKEN=hf_your_token_here

# --- Judge API — PRIMARY (Groq, fast + free tier) -----------------------------
# Sign up at https://console.groq.com (no credit card needed).
# Used at episode end during GRPO training when --use-judge is set.
GROQ_API_KEY=gsk_your_key_here
GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# --- Judge API — FALLBACK (Ollama Cloud, slower but reliable) -----------------
# Auto-used by judge_client.py if Groq fails/rate-limits. Same key as the
# adversarial designer below.
OLLAMA_API_KEY=your_ollama_key_here
OLLAMA_HOST=https://ollama.com
OLLAMA_JUDGE_MODEL=gpt-oss:120b

# --- Adversarial Designer (Phase 3.5) -----------------------------------------
# Separate model var so designer and judge can be tuned independently.
DESIGNER_MODEL=gpt-oss:120b

# --- Optional overrides for inference.py --------------------------------------
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

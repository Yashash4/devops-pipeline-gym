# Round 2 — DevOps Pipeline Gym environment variables
# Copy to .env and fill in values. .env is gitignored; never commit secrets.

# Hugging Face token (required by inference.py + openenv push)
HF_TOKEN=hf_your_token_here

# Ollama Cloud (required for adversarial_designer; graceful fallback if missing)
OLLAMA_API_KEY=your_ollama_cloud_key_here
OLLAMA_HOST=https://ollama.com
DESIGNER_MODEL=gpt-oss:120b

# Optional overrides for inference.py
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
